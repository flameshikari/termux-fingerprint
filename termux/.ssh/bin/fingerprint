#!/data/data/com.termux/files/usr/bin/bash
#
# termux-fingerprint helper: triggers the companion APK to show the system
# BiometricPrompt, reads the JSON result over loopback, and exits 0 on success
# or 1 on any failure. Designed to be used from ssh_config "Match exec" to
# unlock tergent-managed PKCS#11 keys on Android 14, where termux-api's own
# termux-fingerprint is broken (see README § Background).
#
# Usage:
#   fingerprint            run the auth flow (exit 0 = success, 1 = failure)
#   fingerprint -u         update this script to the tag matching installed APK
#   fingerprint --update   same as -u

# Bumped in lockstep with the APK versionName. The -u flow compares this to
# the installed APK version and fetches the matching tag when they diverge.
SCRIPT_VERSION="2.0.0"

PACKAGE=pw.hexed.fingerprint
ACTIVITY=$PACKAGE/.MainActivity
REPO=flameshikari/termux-fingerprint
SCRIPT_RELPATH=termux/.ssh/bin/fingerprint
ADDRESS=127.0.0.1
# Hard deadline for nc to receive the JSON. Slightly above the in-app 30s
# biometric timeout so the Activity always posts before we give up.
DEADLINE=35

# Pulls the tag matching the installed APK version and overwrites this file
# with the script from that tag. No-op if versions already match.
update() {
    local line app_version target tmp url

    # dumpsys package is the non-root path to the installed versionName.
    line=$(dumpsys package "$PACKAGE" 2> /dev/null | grep -m1 'versionName=')
    if [[ -z "$line" ]]; then
        echo "error: package $PACKAGE is not installed or version cannot be read" >&2
        return 1
    fi
    # Strip prefix up to "versionName=" then trim anything after the first space
    # (the line may contain other key=value pairs on some Android builds).
    app_version=${line#*versionName=}
    app_version=${app_version%% *}

    echo "script: $SCRIPT_VERSION"
    echo "app:    $app_version"

    if [[ "$SCRIPT_VERSION" == "$app_version" ]]; then
        echo "already up to date"
        return 0
    fi

    # realpath resolves symlinks so we replace the actual file, not the link.
    target=$(realpath "${BASH_SOURCE[0]}")
    if [[ ! -w "$target" ]]; then
        echo "error: $target is not writable" >&2
        return 1
    fi

    url="https://github.com/$REPO/raw/refs/tags/$app_version/$SCRIPT_RELPATH"
    tmp=$(mktemp)

    echo "fetching $url"
    # -f makes curl exit non-zero on HTTP errors (404 = tag doesn't exist).
    if ! curl -fsSL "$url" -o "$tmp"; then
        rm -f "$tmp"
        echo "error: tag $app_version not found in repository" >&2
        return 1
    fi

    # Sanity check: the downloaded blob must start with a shebang. Guards
    # against CDN/proxy serving an HTML error page with 200 OK.
    if ! head -n1 "$tmp" | grep -q '^#!'; then
        rm -f "$tmp"
        echo "error: downloaded content is not a script" >&2
        return 1
    fi

    chmod +x "$tmp"
    # Bash buffers the script before executing, so overwriting ourselves here
    # is safe as long as the `exit` right after update() returns prevents any
    # further lines from being re-read.
    mv "$tmp" "$target"
    echo "updated to $app_version"
}

case "$1" in
    -u|--update)
        update
        exit $?
        ;;
esac

# Refuse to run inside an SSH session: the script is meant to prompt the
# *local* device for a fingerprint. Without this guard, ssh'ing out from a
# machine that has our ssh_config would chain-trigger local biometric prompts
# on every hop.
[[ -n "$SSH_CLIENT" ]] || [[ -n "$SSH_TTY" ]] && exit 1

# Optional early-exit for "no keys in termux-keystore, nothing to unlock".
# Disabled because `termux-keystore list` does a ~300-500ms IPC roundtrip
# through Termux:API on every call, which dominates the script runtime. If
# keys are missing, SSH will fail shortly anyway.
# eval $(termux-keystore list | jq '(. | length) == 0') && exit 1

# Random ephemeral port avoids collisions with whatever else the user might
# have listening, and prevents a local race where another process could
# predict the port and beat the APK to connect(). Range 30000-59999 stays
# well clear of well-known and typical dynamic ports.
PORT=$((30000 + RANDOM % 30000))
OUTFILE=$(mktemp)
trap 'rm -f "$OUTFILE"' EXIT

# Listener-first: nc is bound before the Activity is launched, so there is
# no window in which the APK's connect() could race ahead of bind().
# `timeout` caps the wait so a crashed Activity can't hang the script.
# `-d` tells nc not to read stdin (we only care about receiving from the APK).
timeout "$DEADLINE" nc -dl "$ADDRESS" "$PORT" > "$OUTFILE" &
NC_PID=$!

# --activity-no-animation sets FLAG_ACTIVITY_NO_ANIMATION on the launch intent;
# --ei port <N> passes the chosen port as an int extra the Activity reads via
# getIntent().getIntExtra("port", -1).
am start --activity-no-animation -n "$ACTIVITY" --ei port "$PORT" &> /dev/null

# Blocks until nc exits: either the APK connected and wrote JSON, or
# `timeout` killed it. No polling.
wait "$NC_PID"

OUTPUT=$(cat "$OUTFILE")
RESULT=$(echo "$OUTPUT" | jq -r '.auth_result // empty' 2> /dev/null)

# Empty RESULT means nc timed out or the APK crashed before writing.
[[ -z "$RESULT" ]] && exit 1

# Pretty-print the JSON to stdout so SSH's Match exec surfaces it to the user.
echo "$OUTPUT" | jq -M

# Final exit code is the truthiness of this test, which is what SSH's
# Match exec uses to decide whether to proceed with key-based auth.
[[ "$RESULT" == 'AUTH_RESULT_SUCCESS' ]]
